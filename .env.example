# Discord Bot
DISCORD_TOKEN=
DISCORD_SERVER_ID=
DISCORD_ROLE_ID=
DISCORD_OUTPUT_CHANNEL_ID=
ADMIN_USER_ID=

# Mode: set to "true" for async mode (DM collection + compiled standup)
# Default (sync mode): just pings the role at standup time to post in the channel
ASYNC_MODE=false

# Schedule (HH:mm in CET)
DM_TIME=09:00
STANDUP_TIME=12:00
STANDUP_DAYS=MON,TUE,WED,THU,FRI

# GitHub
GITHUB_TOKEN=
GITHUB_REPOS=owner/repo1,owner/repo2
